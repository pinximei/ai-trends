# 复制为同目录下的 ssh_local.env 后填写（ssh_local.env 已被 .gitignore，勿提交）
# 用法:
#   py scripts/ssh_connect.py
#   py scripts/deploy_ssh.py          # 若已填 AITRENDS_DEPLOY_HOST，会自动加载本文件

AITRENDS_DEPLOY_HOST=
AITRENDS_DEPLOY_USER=ubuntu
AITRENDS_DEPLOY_SSH_PASSWORD=
# 或密钥（与密码二选一，deploy_ssh 优先用密钥）:
# AITRENDS_DEPLOY_KEY_PATH=%USERPROFILE%\.ssh\id_ed25519
AITRENDS_DEPLOY_SSH_PORT=22
# AITRENDS_DEPLOY_DIR=/opt/aitrends
# AITRENDS_DEPLOY_GIT_BRANCH=main
