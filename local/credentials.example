# 复制为同目录 credentials（已 gitignore，勿提交）
# 本地 SQLite / 诊断脚本 / load_local_credentials.py 均读此文件。
#
#   copy local\credentials.example local\credentials
#   py -3.12 scripts/load_local_credentials.py --db-url sqlite:///D:/aisoul/backend/data/dev_local.db

# —— LLM 润色（DeepSeek 等，OpenAI 兼容）——
AITRENDS_LLM_API_KEY=
AITRENDS_LLM_BASE_URL=https://api.deepseek.com/v1
# 模型固定 deepseek-v4-flash，无需配置 AITRENDS_LLM_MODEL

# Cursor Agent（scripts/cursor_agent_daily.py，与 IDE Auto 同运行时，不用 Hermes）
# 在 Cursor 设置 - Cloud Agents 创建 API Key
CURSOR_API_KEY=
# 兼容旧前缀（二选一即可）
# AISOU_LLM_API_KEY=

# —— NewsAPI https://newsapi.org/register ——
NEWSAPI_KEY=

# —— TheNewsAPI ——
THENEWSAPI_API_TOKEN=

# —— Product Hunt：OAuth 或仅 Access Token ——
# PRODUCT_HUNT_API_KEY=
# PRODUCT_HUNT_APP_SECRET=
# 若只有 token，可只填下一行并留空上面两行
# PRODUCT_HUNT_ACCESS_TOKEN=
