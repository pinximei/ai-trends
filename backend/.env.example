# 默认使用 PostgreSQL（与 docker-compose.yml 一致）。勿再使用 SQLite 作为默认库。
# 复制为 backend/.env 或导出到环境变量后启动 uvicorn。

# 覆盖 test / prod 两套默认 URL（本地 docker-compose 默认库名为 aisoul）
# AISOU_DB_MODE=test
AISOU_DB_URL_TEST=postgresql+psycopg://aisoul:aisoul@127.0.0.1:5432/aisoul
AISOU_DB_URL_PROD=postgresql+psycopg://aisoul:aisoul@127.0.0.1:5432/aisoul

# 或一条 URL 覆盖以上逻辑：
# AISOU_DATABASE_URL=postgresql+psycopg://aisoul:aisoul@127.0.0.1:5432/aisoul

# —— Agent / 连接器文章重写：DeepSeek（OpenAI 兼容 Chat Completions）——
# 真密钥只写在 backend/.env（勿提交 Git）。此处留空或占位。
# 验证连接：在仓库根目录执行  py scripts/test_deepseek_env.py  （会读取 backend/.env）
AISOU_LLM_API_KEY=
AISOU_LLM_BASE_URL=https://api.deepseek.com/v1
AISOU_LLM_MODEL=deepseek-chat
# 其他模型示例（以控制台为准）：deepseek-reasoner 等

# 后台定时：已启用连接器每 N 小时自动同步（默认 6，范围 1～168）
# AISOU_CONNECTOR_SYNC_INTERVAL_HOURS=6
