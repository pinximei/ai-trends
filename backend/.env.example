# 默认使用 PostgreSQL（与 docker-compose.yml 一致）。勿再使用 SQLite 作为默认库。
# 复制为 backend/.env 或导出到环境变量后启动 uvicorn。

# 覆盖 test / prod 两套默认 URL（本地 docker-compose 默认库名为 aitrends）
# AITRENDS_DB_MODE=test
AITRENDS_DB_URL_TEST=postgresql+psycopg://aitrends:aitrends@127.0.0.1:5432/aitrends
AITRENDS_DB_URL_PROD=postgresql+psycopg://aitrends:aitrends@127.0.0.1:5432/aitrends

# 或一条 URL 覆盖以上逻辑：
# AITRENDS_DATABASE_URL=postgresql+psycopg://aitrends:aitrends@127.0.0.1:5432/aitrends

# —— Agent / 连接器文章重写：DeepSeek（OpenAI 兼容 Chat Completions）——
# 真密钥只写在 backend/.env（勿提交 Git）。此处留空或占位。
# 验证连接：在仓库根目录执行  py scripts/test_deepseek_env.py  （会读取 backend/.env）
AITRENDS_LLM_API_KEY=
AITRENDS_LLM_BASE_URL=https://api.deepseek.com/v1
AITRENDS_LLM_MODEL=deepseek-v4-flash
# 其他模型（以控制台为准）：deepseek-v4-pro（推理更重）、deepseek-reasoner（旧别名，将退役）

# 新建库时「连接器整批同步」默认间隔（小时，1～168）；写入 DB 后改管理端即可，不必依赖本变量。
# AITRENDS_CONNECTOR_SYNC_INTERVAL_HOURS=6

# 可选：公开页 /api/public/v1/version 返回的发布串（与前端 Vite 构建的 VITE_APP_RELEASE 对照，避免「页面旧、接口新」难排查）
# 建议与 git 短 SHA 一致，例如 deploy 后执行:  git rev-parse --short HEAD
# AITRENDS_APP_RELEASE=0.1.0+8ee05b6
# AITRENDS_GIT_SHA=8ee05b6

# 公开站根 URL（sitemap.xml、邮件退订链接；与前台 VITE_PUBLIC_SITE_URL 保持一致）
# AITRENDS_PUBLIC_BASE_URL=https://www.ai-trends.news

# —— 以下多数已有「库内默认值」，可在管理端「账号管理 → 运行参数」覆盖（product_settings_kv.runtime）——
# 未建库或首次启动前仍以环境变量为准；保存后即读内存快照，无需重启（CORS / JWT 时长 / app_env 等）。
# AITRENDS_CORS_ORIGINS=https://ai-trends.news,https://www.ai-trends.news,http://127.0.0.1:5172
# AITRENDS_JWT_TTL_SECONDS=1800
# AITRENDS_ALLOWED_SKEW_SECONDS=300
# AITRENDS_REQUIRE_HTTPS=true
# AITRENDS_ALLOW_INSECURE_LOCALHOST=true
# AITRENDS_ADMIN_COOKIE_SECURE=true
# AITRENDS_ENV=dev
# AITRENDS_ENABLE_DEMO_SEED=
# AITRENDS_LEGACY_ADMIN_ENABLED=false
# AITRENDS_HOT_LLM_MODEL=rule-based

# —— 必须保留在环境变量（勿入库）：连接串、签名根密钥、内部 bootstrap、旧版 admin token ——
# AITRENDS_JWT_SECRET=
# AITRENDS_SIGNING_KEY=
# AITRENDS_AUTH_BOOTSTRAP_KEY=
# AITRENDS_ADMIN_TOKEN=
# （以及上方 AITRENDS_DATABASE_URL / AITRENDS_LLM_API_KEY 等真密钥）
