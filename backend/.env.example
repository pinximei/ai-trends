# 默认使用 PostgreSQL（与 docker-compose.yml 一致）。勿再使用 SQLite 作为默认库。
# 复制为 backend/.env 或导出到环境变量后启动 uvicorn。

# 覆盖 test / prod 两套默认 URL（本地 docker-compose 默认库名为 aisoul）
# AISOU_DB_MODE=test
AISOU_DB_URL_TEST=postgresql+psycopg://aisoul:aisoul@127.0.0.1:5432/aisoul
AISOU_DB_URL_PROD=postgresql+psycopg://aisoul:aisoul@127.0.0.1:5432/aisoul

# 或一条 URL 覆盖以上逻辑：
# AISOU_DATABASE_URL=postgresql+psycopg://aisoul:aisoul@127.0.0.1:5432/aisoul

# —— Agent / 连接器文章重写：DeepSeek（OpenAI 兼容 Chat Completions）——
# 真密钥只写在 backend/.env（勿提交 Git）。此处留空或占位。
# 验证连接：在仓库根目录执行  py scripts/test_deepseek_env.py  （会读取 backend/.env）
AISOU_LLM_API_KEY=
AISOU_LLM_BASE_URL=https://api.deepseek.com/v1
AISOU_LLM_MODEL=deepseek-chat
# 其他模型示例（以控制台为准）：deepseek-reasoner 等

# 新建库时「连接器整批同步」默认间隔（小时，1～168）；写入 DB 后改管理端即可，不必依赖本变量。
# AISOU_CONNECTOR_SYNC_INTERVAL_HOURS=6

# 可选：公开页 /api/public/v1/version 返回的发布串（与前端 Vite 构建的 VITE_APP_RELEASE 对照，避免「页面旧、接口新」难排查）
# 建议与 git 短 SHA 一致，例如 deploy 后执行:  git rev-parse --short HEAD
# AISOU_APP_RELEASE=0.1.0+8ee05b6
# AISOU_GIT_SHA=8ee05b6

# —— 以下多数已有「库内默认值」，可在管理端「账号管理 → 运行参数」覆盖（product_settings_kv.runtime）——
# 未建库或首次启动前仍以环境变量为准；保存后即读内存快照，无需重启（CORS / JWT 时长 / app_env 等）。
# AISOU_CORS_ORIGINS=https://ai-trends.news,https://www.ai-trends.news,http://127.0.0.1:5172
# AISOU_JWT_TTL_SECONDS=1800
# AISOU_ALLOWED_SKEW_SECONDS=300
# AISOU_REQUIRE_HTTPS=true
# AISOU_ALLOW_INSECURE_LOCALHOST=true
# AISOU_ADMIN_COOKIE_SECURE=true
# AISOU_ENV=dev
# AISOU_ENABLE_DEMO_SEED=
# AISOU_LEGACY_ADMIN_ENABLED=false
# AISOU_HOT_LLM_MODEL=rule-based

# —— 必须保留在环境变量（勿入库）：连接串、签名根密钥、内部 bootstrap、旧版 admin token ——
# AISOU_JWT_SECRET=
# AISOU_SIGNING_KEY=
# AISOU_AUTH_BOOTSTRAP_KEY=
# AISOU_ADMIN_TOKEN=
# （以及上方 AISOU_DATABASE_URL / AISOU_LLM_API_KEY 等真密钥）
